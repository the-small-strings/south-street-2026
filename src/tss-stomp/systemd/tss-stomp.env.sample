# Optional environment values for tss-stomp service.
# Copy to /etc/default/tss-stomp (the install script will do this on first install).

# Base URL for the game API.
# Default in code (if unset): http://192.168.123.100:33001
# API_BASE_URL=http://192.168.1.101:33001

# Use mock GPIO pin mappings instead of real hardware mappings.
# Valid values: true | false
# Default in code (if unset): false
# USE_MOCK_GPIO=false
